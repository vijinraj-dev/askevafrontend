# Base URL for the real backend API.
# The app currently runs against an in-browser mock API layer
# (see src/services/mockDb.ts and src/services/mockAuth.ts) so it works
# with zero backend setup. Point this at a real API and wire up
# src/api/employeeApi.ts / src/api/authApi.ts to axiosClient calls to go live.
VITE_API_BASE_URL=http://localhost:4000/api
